---
import { Image } from "astro:assets";
import { Maximize2, Camera, Hammer, PaintBucket, ChevronRight } from "lucide-react";

// Importación de imágenes (Estas deberás agregarlas a src/assets/)
import proyect1 from "../../assets/galeria-1.jpg";
import proyect2 from "../../assets/galeria-2.jpg";
import proyect3 from "../../assets/galeria-3.jpg";
import proyect4 from "../../assets/galeria-4.jpg";
import proyect5 from "../../assets/galeria-5.jpg";
import proyect6 from "../../assets/galeria-6.jpg";

const projects = [
  { img: proyect1, title: "Reforma Integral", category: "Reformas", size: "lg" },
  { img: proyect2, title: "Fachada Moderna", category: "Obra Nueva", size: "md" },
  { img: proyect3, title: "Detalle de Pintura", category: "Acabados", size: "md" },
  { img: proyect4, title: "Interiores Durlock", category: "Reformas", size: "md" },
  { img: proyect5, title: "Estructura Hormigón", category: "Obra Nueva", size: "md" },
  { img: proyect6, title: "Terminación Llave en Mano", category: "Reformas", size: "lg" },
];
---

<section id="galeria" class="relative bg-surface-100 overflow-hidden">
  <div class="container relative z-10 mx-auto px-6 md:px-12">
    
    <!-- HEADER BLOCK (BRICK STYLE - CONSISTENTE CON SERVICIOS) -->
    <div class="bg-surface-100 border-x border-t border-surface-300 p-8 lg:p-16 text-center lg:text-left animate-reveal">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10">
        <div class="max-w-3xl">
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-6">
            <span class="text-primary text-xs font-bold uppercase tracking-[0.4em]">
              Portfolio Visual
            </span>
          </div>
          <h2 class="text-4xl md:text-6xl lg:text-7xl font-title text-secondary leading-none uppercase">
            Nuestros Trabajos <span class="text-primary italic">Terminados.</span>
          </h2>
        </div>
        <div class="max-w-xs mx-auto lg:mx-0 lg:border-l-2 lg:border-primary lg:pl-8">
          <p class="text-secondary/70 text-lg font-body leading-relaxed">
            La calidad constructiva no se explica, se muestra. Cada proyecto es un testimonio de nuestro compromiso.
          </p>
        </div>
      </div>
    </div>

    <!-- BENTO GRID DE GALERÍA -->
    <!-- gap-px y bg-surface-300 para mantener la estética de juntas de ladrillo -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-surface-300 border border-surface-300">
      {projects.map((project, index) => (
        <div class={`group relative overflow-hidden bg-secondary animate-reveal`} style={`animation-delay: ${index * 100}ms`}>
          <!-- Contenedor de Imagen -->
          <div class="aspect-[4/3] lg:aspect-square overflow-hidden">
            <Image 
              src={project.img} 
              alt={project.title}
              class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:opacity-40"
            />
          </div>

          <!-- Overlay Industrial -->
          <div class="absolute inset-0 p-8 flex flex-col justify-end opacity-0 group-hover:opacity-100 transition-all duration-500">
             <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                <span class="text-primary font-bold text-xs uppercase tracking-widest mb-2 block">{project.category}</span>
                <h3 class="text-white font-title text-4xl uppercase mb-4 leading-none">{project.title}</h3>
                
                <div class="flex items-center gap-4">
                  <div class="w-10 h-[2px] bg-primary"></div>
                  <Maximize2 className="text-white w-5 h-5" />
                </div>
             </div>
          </div>

          <!-- Badge flotante (Esquina) -->
          <div class="absolute top-4 right-4 bg-white/10 backdrop-blur-md p-2 border border-white/10 opacity-0 group-hover:opacity-100 transition-opacity">
              <Camera className="text-white w-4 h-4" />
          </div>
        </div>
      ))}
    </div>

    <!-- FOOTER BLOCK (BRICK STYLE) -->
    <div class="bg-surface-100 border-x border-b border-surface-300 p-8 lg:p-12 animate-reveal">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left">
            <div class="flex flex-col lg:flex-row items-center gap-6">
               <div class="flex -space-x-4">
                   <div class="w-12 h-12 rounded-full border-4 border-white bg-primary flex items-center justify-center">
                        <Hammer className="text-white w-5 h-5" />
                   </div>
                   <div class="w-12 h-12 rounded-full border-4 border-white bg-secondary flex items-center justify-center">
                        <PaintBucket className="text-white w-5 h-5" />
                   </div>
               </div>
               <div class="flex flex-col">
                   <span class="text-secondary font-title text-2xl leading-none">¿Tenés un proyecto en mente?</span>
                   <span class="text-secondary/50 text-[11px] font-bold uppercase tracking-widest italic">Hagamos realidad tu idea</span>
               </div>
            </div>

            <p class="font-title text-2xl text-secondary max-w-sm">
                TRABAJAMOS CON <span class="text-primary">PLANOS RIGUROSOS</span> Y TIEMPOS PACTADOS, PARA QUE TU PROYECTO SEA REALIDAD.
            </p>

            <a href="#contacto" class="bg-primary text-white font-title text-xl px-10 py-4 hover:bg-primary-dark transition-all shadow-lg shadow-primary/20">
                PEDIR COTIZACIÓN
            </a>
        </div>
    </div>
  </div>
</section>

<style>
  .animate-reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Efecto visual de Zoom en hover para evitar layout shifts */
  .group:hover img {
    filter: brightness(0.6);
  }
</style>