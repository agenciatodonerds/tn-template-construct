---
import {
  HardHat,
  MapPin,
  Phone,
  Mail,
  Instagram,
  Facebook,
  Linkedin,
  ArrowUp,
  Hammer,
} from "lucide-react";

const links = [
  { name: "Inicio", href: "#inicio" },
  { name: "Servicios", href: "#servicios" },
  { name: "Galería", href: "#galeria" },
  { name: "Testimonios", href: "#testimonios" },
];

const specialties = [
  "Albañilería de Precisión",
  "Reformas e Interiores",
  "Pintura e Impermeabilización",
  "Durlock y Steel Framing",
];
---

<footer
  class="relative bg-secondary border-t border-white/5 pt-16 pb-12 overflow-hidden"
>
  <!-- Decoración técnica sutil de fondo -->
  <div
    class="absolute bottom-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-[120px] pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-6">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 text-center lg:text-left"
    >
      <!-- COLUMNA 1: IDENTIDAD -->
      <div class="flex flex-col items-center lg:items-start gap-6">
        <a href="#inicio" class="flex items-center gap-3 group">
          <div
            class="p-2.5 bg-primary rounded-sm transition-all duration-500 group-hover:rotate-12 group-hover:scale-110 shadow-lg shadow-primary/20"
          >
            <HardHat className="text-white w-5 h-5" />
          </div>
          <div class="flex flex-col text-left">
            <span
              class="text-white font-title text-2xl leading-none uppercase tracking-wider"
              >TodoNerds</span
            >
            <span
              class="text-primary text-[10px] uppercase tracking-[0.4em] font-bold"
              >Construcciones</span
            >
          </div>
        </a>
        <p
          class="text-surface-300/50 text-sm leading-relaxed max-w-xs mx-auto lg:mx-0 font-body"
        >
          Transformamos planos en estructuras sólidas. Excelencia técnica y
          materiales de alta calidad para su proyecto.
        </p>

        <!-- REDES SOCIALES -->
        <div class="flex gap-4">
          <a
            href="#"
            class="p-3 bg-white/5 border border-white/5 text-surface-200 hover:text-primary hover:border-primary transition-all hover:-translate-y-1"
            aria-label="Instagram"
          >
            <Instagram className="w-4 h-4" />
          </a>
          <a
            href="#"
            class="p-3 bg-white/5 border border-white/5 text-surface-200 hover:text-primary hover:border-primary transition-all hover:-translate-y-1"
            aria-label="Facebook"
          >
            <Facebook className="w-4 h-4" />
          </a>
          <a
            href="#"
            class="p-3 bg-white/5 border border-white/5 text-surface-200 hover:text-primary hover:border-primary transition-all hover:-translate-y-1"
            aria-label="LinkedIn"
          >
            <Linkedin className="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- COLUMNA 2: NAVEGACIÓN -->
      <div class="flex flex-col items-center lg:items-start gap-6">
        <h4
          class="text-white font-title uppercase tracking-[0.2em] text-xs flex items-center gap-2 border-b border-primary/30 pb-1"
        >
          <Hammer className="w-3 h-3 text-primary" /> Menú Técnico
        </h4>
        <nav>
          <ul class="flex flex-col gap-4">
            {
              links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-surface-300/70 hover:text-primary text-sm transition-colors font-medium tracking-wide uppercase font-body"
                  >
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <!-- COLUMNA 3: ESPECIALIDADES -->
      <div class="flex flex-col items-center lg:items-start gap-6">
        <h4
          class="text-white font-title uppercase tracking-[0.2em] text-xs border-b border-primary/30 pb-1"
        >
          Especialidades
        </h4>
        <ul
          class="flex flex-col gap-4 text-surface-300/70 text-sm font-medium tracking-wide font-body"
        >
          {
            specialties.map((item) => (
              <li class="hover:text-white transition-colors cursor-default">
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- COLUMNA 4: CONTACTO -->
      <div class="flex flex-col items-center lg:items-start gap-6">
        <h4
          class="text-white font-title uppercase tracking-[0.2em] text-xs border-b border-primary/30 pb-1"
        >
          Contacto Directo
        </h4>
        <ul class="flex flex-col gap-5 text-surface-300/70 text-sm font-body">
          <li
            class="flex flex-col items-center lg:items-start gap-2 group cursor-pointer"
          >
            <div
              class="flex items-center gap-3 group-hover:text-primary transition-colors"
            >
              <MapPin className="text-primary w-4 h-4" />
              <span class="font-medium">Tu Ciudad, País</span>
            </div>
          </li>
          <li
            class="flex flex-col items-center lg:items-start gap-2 group cursor-pointer"
          >
            <div
              class="flex items-center gap-3 group-hover:text-primary transition-colors"
            >
              <Phone className="text-primary w-4 h-4" />
              <span class="font-medium">+54 3541 123456</span>
            </div>
          </li>
          <li
            class="flex flex-col items-center lg:items-start gap-2 group cursor-pointer"
          >
            <div
              class="flex items-center gap-3 group-hover:text-primary transition-colors"
            >
              <Mail className="text-primary w-4 h-4" />
              <span class="font-medium">obra@todonerds.pro</span>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- SECCIÓN INFERIOR -->
    <div
      class="mt-20 pt-10 border-t border-white/5 flex flex-col items-center text-center gap-6"
    >
      <p
        class="text-[10px] md:text-[11px] text-surface-300/40 uppercase tracking-[0.3em] font-medium max-w-2xl font-body"
      >
        © {new Date().getFullYear()} TodoNerds Construcciones. Todos los derechos
        reservados. Presupuestos bajo normas de calidad técnica vigente.
      </p>

      <!-- CRÉDITO DE AGENCIA (Tu Sello) -->
      <a
        href="https://todonerdsagency.web.app"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-1 opacity-30 hover:opacity-100 transition-opacity"
      >
        <span
          class="text-[9px] uppercase font-bold tracking-[0.4em] text-surface-300"
        >
          Arquitectura Digital por
        </span>
        <div class="flex items-center gap-1">
          <span class="text-sm font-title text-white uppercase tracking-widest">
            Todo<span class="text-primary">Nerds</span> Agency
          </span>
        </div>
      </a>
    </div>
  </div>

  <!-- BOTÓN VOLVER ARRIBA -->
  <a
    href="#inicio"
    id="back-to-top"
    class="fixed bottom-8 right-8 z-40 p-4 bg-primary text-white border border-primary/20 hover:bg-primary-dark transition-all duration-500 scale-0 translate-y-10 shadow-[0_0_20px_rgba(242,100,25,0.4)]"
    aria-label="Subir al inicio"
  >
    <ArrowUp className="w-5 h-5" />
  </a>
</footer>

<script>
  const backToTop = document.getElementById("back-to-top");

  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 800) {
        backToTop?.classList.remove("scale-0", "translate-y-10");
        backToTop?.classList.add("scale-100", "translate-y-0");
      } else {
        backToTop?.classList.add("scale-0", "translate-y-10");
        backToTop?.classList.remove("scale-100", "translate-y-0");
      }
    },
    { passive: true },
  );
</script>

<style>
  footer {
    /* Refuerzo del tono secundario oscuro para profundidad industrial */
    background-image: radial-gradient(
      circle at 1px 1px,
      rgba(255, 255, 255, 0.01) 1px,
      transparent 0
    );
    background-size: 20px 20px;
  }
</style>
