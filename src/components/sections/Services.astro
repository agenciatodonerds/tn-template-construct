---
import { Hammer, LayoutDashboard, PaintBucket, HardHat, ShieldCheck, ChevronRight } from "lucide-react";

const services = [
  {
    id: "01",
    icon: Hammer,
    title: "Albañilería y Obra Civil",
    desc: "Desde cimientos hasta estructuras complejas. Construcción robusta cumpliendo normativas de seguridad y cálculos de ingeniería precisos.",
    tags: ["Hormigón", "Ladrillo", "Estructuras"]
  },
  {
    id: "02",
    icon: LayoutDashboard,
    title: "Reformas e Interiores",
    desc: "Especialistas en Durlock y remodelaciones integrales. Optimizamos espacios con terminaciones nivel arquitectónico y diseño funcional.",
    tags: ["Durlock", "Tabiquería", "Drywall"]
  },
  {
    id: "03",
    icon: PaintBucket,
    title: "Pintura y Acabados",
    desc: "Tratamiento de superficies y aplicaciones industriales. Utilizamos materiales de alta resistencia para un acabado impecable y duradero.",
    tags: ["Látex", "Satinado", "Revoques"]
  },
  {
    id: "04",
    icon: HardHat,
    title: "Servicios Llave en Mano",
    desc: "Gestión total del proyecto. Desde la planificación técnica hasta la entrega final, eliminando fricciones para el propietario.",
    tags: ["Gestión", "Supervisión", "Finalización"]
  },
];
---

<section id="servicios" class="relative py-12 md:py-24 bg-surface-100 overflow-hidden">
  <div class="container relative z-10 mx-auto px-6 md:px-12">
    
    <!-- HEADER BLOCK (BRICK STYLE) -->
    <div class="bg-surface-100 border-x border-t border-surface-300 p-8 lg:p-16 text-center lg:text-left animate-reveal">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10">
        <div class="max-w-3xl">
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-6">
            <span class="text-primary text-xs font-bold uppercase tracking-[0.4em]">
              Expertos en Ejecución
            </span>
          </div>
          <h2 class="text-4xl md:text-6xl lg:text-7xl font-title text-secondary leading-none uppercase">
            Servicios de <span class="text-primary italic">Alta Capacidad</span> Técnica.
          </h2>
        </div>
        <div class="max-w-xs mx-auto lg:mx-0 lg:border-l-2 lg:border-primary lg:pl-8">
          <p class="text-secondary/70 text-lg font-body leading-relaxed">
            Nuestras soluciones combinan la fuerza del material bruto con la precisión de la arquitectura moderna.
          </p>
        </div>
      </div>
    </div>

    <!-- GRID DE SERVICIOS -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-surface-300 border border-surface-300">
      {services.map((service, index) => (
        <div 
          class="group relative p-8 bg-surface-100 hover:bg-secondary transition-all duration-500 animate-reveal flex flex-col min-h-[440px]"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Numero de Serie ID -->
          <span class="absolute top-6 right-8 font-title text-4xl text-surface-300 group-hover:text-white/20 transition-colors">
            {service.id}
          </span>

          <!-- Icono Cuadrado -->
          <div class="mb-12 w-16 h-16 bg-secondary group-hover:bg-primary flex items-center justify-center relative overflow-hidden transition-all duration-500 shadow-xl shadow-secondary/10 group-hover:shadow-primary/20">
             <service.icon className="text-white w-8 h-8 group-hover:scale-110 transition-transform" />
          </div>

          <h3 class="text-3xl font-title text-secondary group-hover:text-white mb-5 tracking-tight transition-colors">
            {service.title}
          </h3>
          
          <p class="text-secondary/80 group-hover:text-surface-200 text-[15px] leading-relaxed mb-8 font-body flex-grow transition-colors">
            {service.desc}
          </p>

          <!-- Tags Técnicas -->
          <div class="flex flex-wrap gap-2 mb-8">
            {service.tags.map(tag => (
               <span class="text-[10px] uppercase font-bold bg-surface-300/50 group-hover:bg-white/10 px-2 py-0.5 border border-surface-400/20 group-hover:border-primary/50 text-secondary/60 group-hover:text-primary transition-all tracking-wider">
                  {tag}
               </span>
            ))}
          </div>

          <a href="#contacto" class="flex items-center gap-2 text-secondary group-hover:text-primary font-bold text-xs uppercase tracking-[0.2em] transition-all">
             Consultar Servicio
             <ChevronRight className="w-4 h-4 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      ))}
    </div>

    <!-- FOOTER BLOCK (BRICK STYLE) -->
    <div class="bg-surface-100 border-x border-b border-surface-300 p-8 lg:p-12 animate-reveal [animation-delay:800ms]">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left">
            <div class="flex flex-col lg:flex-row items-center gap-6">
               <div class="p-4 bg-surface-200 rounded-sm">
                   <ShieldCheck className="text-primary w-10 h-10" />
               </div>
               <div class="flex flex-col">
                   <span class="text-secondary font-title text-2xl leading-none mb-1">Certificación IRAM / ISO</span>
                   <span class="text-secondary/50 text-[11px] font-bold uppercase tracking-widest">Materiales de calidad garantizada</span>
               </div>
            </div>
            
            <div class="hidden lg:block h-12 w-px bg-surface-300"></div>

            <p class="font-title text-3xl md:text-4xl text-secondary">
              OBRA CIVIL <span class="text-primary">CON PRECISIÓN</span> INDUSTRIAL
            </p>
        </div>
    </div>
  </div>
</section>

<style>
  .animate-reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Efecto sutil para evitar layout shifts en la grilla */
  .grid {
    will-change: transform;
  }
</style>