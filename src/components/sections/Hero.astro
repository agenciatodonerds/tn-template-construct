---
import { Image } from "astro:assets";
import heroImage from "../../assets/hero-work.jpg"; // Asegúrate de tener esta imagen
import { HardHat, Ruler, Drill, ChevronRight } from "lucide-react";
---

<section
  id="inicio"
  class="relative min-h-screen md:min-h-[100dvh] w-full flex items-center overflow-hidden bg-surface-900"
>
  <!-- 1. CAPA DE FONDO: Enfoque Técnico -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImage}
      alt="Obra premium TodoNerds - Calidad constructiva"
      class="w-full h-full object-cover grayscale-[20%] opacity-50 scale-105 animate-subtle-zoom"
      widths={[720, 1280, 1920]}
      loading="eager"
      fetchpriority="high"
    />
    <!-- Overlay: De oscuro (industrial) a color primario (acción) -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-surface-900 via-surface-900/60 to-transparent"
    >
    </div>
    <!-- Decoración de Grilla (Simula papel milimetrado de arquitecto) -->
    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(242,100,25,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(242,100,25,0.05)_1px,transparent_1px)] bg-[size:40px_40px]"
    >
    </div>
  </div>

  <!-- 2. CONTENIDO: Disposición Invertida y Asimétrica -->
  <div class="container relative z-10 mx-auto px-6 md:px-12 pt-32 pb-16">
    <div class="grid lg:grid-cols-12 gap-8 items-end">
      <!-- COLUMNA DERECHA (Ahora contenido principal para variar del estilo legal) -->
      <div class="lg:col-span-8 xl:col-span-9 lg:order-2">
        <!-- Badge de Status -->
        <div
          class="inline-flex items-center gap-2 px-3 py-1 bg-primary text-white mb-6 animate-reveal"
        >
          <HardHat className="w-4 h-4 text-white" />
          <span
            class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em]"
          >
            Certificación en Obra Civil y Reformas
          </span>
        </div>

        <h1
          class="text-white text-5xl md:text-8xl lg:text-[100px] leading-[0.85] font-title mb-6 animate-reveal [animation-delay:200ms] uppercase tracking-tighter"
        >
          Construimos <br />
          <span
            class="text-transparent stroke-white"
            style="-webkit-text-stroke: 1px white;">Con Presición.</span
          ><br />
          <span class="text-primary">Vivimos con calidad.</span>
        </h1>

        <div
          class="grid md:grid-cols-2 gap-8 items-start animate-reveal [animation-delay:400ms]"
        >
          <p
            class="text-surface-200 text-lg md:text-xl font-body leading-relaxed max-w-md border-l-2 border-primary pl-6"
          >
            Albañilería de alto nivel, pintura industrial y reformas integrales.
            Convertimos sus planos en realidades tangibles y duraderas.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <a
              href="https://wa.me/tunumerowhatsapp"
              class="group bg-primary hover:bg-primary-dark text-white font-title text-xl px-10 py-5 transition-all flex items-center justify-center gap-3 shadow-2xl shadow-primary/20"
            >
              PRESUPUESTAR
            </a>
            <a
              href="#proyectos"
              class="bg-transparent border border-white/20 hover:border-white text-white font-title text-xl px-10 py-5 transition-all flex items-center justify-center"
            >
              GALERÍA
            </a>
          </div>
        </div>
      </div>

      <!-- COLUMNA IZQUIERDA: "Ficha Técnica" Lateral -->
      <div
        class="lg:col-span-4 xl:col-span-3 lg:order-1 hidden lg:block animate-reveal [animation-delay:600ms]"
      >
        <div
          class="bg-surface-200/5 backdrop-blur-md border border-white/10 p-8 relative overflow-hidden group"
        >
          <!-- Pestaña lateral decorativa -->
          <div
            class="absolute top-0 right-0 w-1.5 h-full bg-primary transform origin-bottom transition-transform group-hover:scale-y-110"
          >
          </div>

          <ul class="space-y-10">
            <li class="flex flex-col gap-2">
              <Ruler className="text-primary w-6 h-6" />
              <span
                class="text-white font-title text-2xl tracking-wide uppercase leading-none"
                >Presupuesto Sin Cargo</span
              >
              <span
                class="text-surface-300 text-xs font-body leading-none uppercase tracking-widest"
                >En menos de 48hs hábiles</span
              >
            </li>
            <li class="flex flex-col gap-2">
              <Drill className="text-primary w-6 h-6" />
              <span
                class="text-white font-title text-2xl tracking-wide uppercase leading-none"
                >Entrega Puntual</span
              >
              <span
                class="text-surface-300 text-xs font-body leading-none uppercase tracking-widest"
                >Cronogramas de obra rígidos</span
              >
            </li>
          </ul>

          <div class="mt-12 flex flex-col pt-8 border-t border-white/10">
            <span class="text-primary font-title text-4xl leading-none"
              >100%</span
            >
            <span
              class="text-white text-[10px] font-bold uppercase tracking-widest"
              >Clientes que nos recomiendan</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- INDICADOR DE POSICIÓN (Vertical Moderno) -->
  <div
    class="absolute right-6 top-1/2 -translate-y-1/2 hidden xl:flex flex-col items-center gap-8"
  >
    <span
      class="[writing-mode:vertical-lr] text-white/30 text-[10px] tracking-[0.5em] font-bold uppercase"
      >Proyectos 2024</span
    >
    <div class="w-px h-24 bg-gradient-to-b from-primary to-transparent"></div>
  </div>
</section>

<style>
  .animate-reveal {
    opacity: 0;
    transform: translateY(30px);
    animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-subtle-zoom {
    animation: slowZoom 15s ease-in-out infinite alternate;
  }

  @keyframes slowZoom {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1.15);
    }
  }

  /* Efecto de stroke para el texto (Opcional según estilo) */
  .text-transparent {
    color: transparent;
  }
</style>
