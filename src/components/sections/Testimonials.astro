---
import { Star, Quote, UserCircle2, CheckCircle2 } from "lucide-react";

const testimonials = [
  {
    name: "Carlos Rodríguez",
    role: "Propietario Residencia",
    project: "Reforma Integral de Cocina",
    text: "Cumplieron con los plazos pactados desde el primer día. La prolijidad del equipo de pintura y la atención al detalle en el Durlock fue sobresaliente.",
    rating: 5
  },
  {
    name: "Arquitecta Elena S.",
    role: "Directora de Obra",
    project: "Estructura Edificio Local",
    text: "Trabajar con TodoNerds facilita la supervisión. Su capacidad técnica para resolver imprevistos en la obra civil los pone un escalón por encima.",
    rating: 5
  },
  {
    name: "Marcelo Gómez",
    role: "Gerente Comercial",
    project: "Mantenimiento Industrial",
    text: "Excelente respuesta técnica. Realizaron el tratamiento de superficies en nuestra planta sin interrumpir la operación. Profesionales de verdad.",
    rating: 5
  }
];
---

<section id="testimonios" class="relative py-12 md:py-24 bg-surface-100 overflow-hidden">
  <div class="container relative z-10 mx-auto px-6 md:px-12">
    
    <!-- HEADER BLOCK (BRICK STYLE - CONSISTENTE) -->
    <div class="bg-surface-100 border-x border-t border-surface-300 p-8 lg:p-16 text-center lg:text-left animate-reveal">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10">
        <div class="max-w-3xl">
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-6">
            <span class="text-primary text-xs font-bold uppercase tracking-[0.4em]">
              Garantía de Confianza
            </span>
          </div>
          <h2 class="text-4xl md:text-6xl lg:text-7xl font-title text-secondary leading-none uppercase">
            Lo que dicen <span class="text-primary italic">nuestros clientes.</span>
          </h2>
        </div>
        <div class="max-w-xs mx-auto lg:mx-0 lg:border-l-2 lg:border-primary lg:pl-8 text-center lg:text-left">
          <p class="text-secondary/70 text-lg font-body leading-relaxed">
            Más de 500 metros cuadrados construidos y cientos de clientes que avalan nuestra metodología.
          </p>
        </div>
      </div>
    </div>

    <!-- GRID DE TESTIMONIOS (Service Card Style) -->
    <div class="grid md:grid-cols-3 gap-px bg-surface-300 border border-surface-300">
      {testimonials.map((t, index) => (
        <div 
          class="group relative p-10 bg-surface-100 hover:bg-secondary transition-all duration-500 animate-reveal flex flex-col"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Icono Quote de fondo (Sutil) -->
          <Quote className="absolute top-10 right-10 w-12 h-12 text-surface-200 group-hover:text-white/10 transition-colors" />

          <!-- Estrellas (Technical Rating) -->
          <div class="flex gap-1 mb-6">
            {[...Array(t.rating)].map(() => (
              <Star className="w-4 h-4 fill-primary text-primary" />
            ))}
          </div>

          <!-- Texto de Testimonio -->
          <blockquote class="text-secondary/80 group-hover:text-surface-200 text-lg leading-relaxed mb-10 font-body flex-grow italic">
            "{t.text}"
          </blockquote>

          <!-- User Info (Brick Info Style) -->
          <div class="pt-8 border-t border-surface-300 group-hover:border-white/20 flex flex-col gap-1">
             <div class="flex items-center gap-2 mb-2 text-primary">
                 <CheckCircle2 className="w-4 h-4" />
                 <span class="text-[10px] uppercase font-bold tracking-[0.2em]">{t.project}</span>
             </div>
             <cite class="not-italic">
                <span class="block text-secondary group-hover:text-white font-title text-3xl leading-none uppercase">
                   {t.name}
                </span>
                <span class="text-secondary/50 group-hover:text-primary/70 text-[11px] font-bold uppercase tracking-widest">
                   {t.role}
                </span>
             </cite>
          </div>
        </div>
      ))}
    </div>

    <!-- FOOTER BLOCK (BRICK STYLE) -->
    <div class="bg-surface-100 border-x border-b border-surface-300 p-8 lg:p-12 animate-reveal">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left">
            <div class="flex flex-col lg:flex-row items-center gap-6">
               <div class="w-14 h-14 bg-surface-900 rounded-sm flex items-center justify-center">
                    <UserCircle2 className="text-white w-8 h-8" />
               </div>
               <div class="flex flex-col">
                   <span class="text-secondary font-title text-2xl leading-none">Seguridad Jurídica y Civil</span>
                   <span class="text-secondary/50 text-[11px] font-bold uppercase tracking-widest italic">Contratos de obra claros y transparentes</span>
               </div>
            </div>
            
            <div class="hidden lg:block h-12 w-px bg-surface-300"></div>

            <p class="font-title text-2xl text-secondary max-w-[280px]">
                RESEÑAS <span class="text-primary">VERIFICABLES</span> EN GOOGLE MAPS Y NUESTRO PORTAL DE CLIENTES.
            </p>

            <div class="flex gap-4">
                 <div class="flex flex-col items-center">
                    <span class="font-title text-4xl text-secondary leading-none">4.9</span>
                    <div class="flex gap-0.5 mt-1">
                        <Star className="w-2.5 h-2.5 fill-primary text-primary" />
                        <Star className="w-2.5 h-2.5 fill-primary text-primary" />
                        <Star className="w-2.5 h-2.5 fill-primary text-primary" />
                        <Star className="w-2.5 h-2.5 fill-primary text-primary" />
                        <Star className="w-2.5 h-2.5 fill-primary text-primary" />
                    </div>
                 </div>
            </div>
        </div>
    </div>
  </div>
</section>

<style>
  .animate-reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Evitar layout shifts */
  blockquote {
    min-height: 4.5rem;
  }
</style>